# ============================================================================
# .env.example — mojalab-vps-stack
# ============================================================================
# Copy this file to `.env` and fill in real values:
#
#   cp .env.example .env
#   vim .env
#
# NEVER commit .env to git. It's already in .gitignore.
# ============================================================================

# ----------------------------------------------------------------------------
# Your domain (without www, without protocol)
# Required DNS A records: auth.${DOMAIN}, files.${DOMAIN}, term.${DOMAIN},
# stats.${DOMAIN} — all pointing to your VPS public IP.
# ----------------------------------------------------------------------------
DOMAIN=lab.example.com

# Timezone for all containers (logs, scheduling)
TZ=Europe/Rome

# ----------------------------------------------------------------------------
# Where to put the lab user's persistent state on the host (bind-mounted into
# the zellij container). Holds: pip --user installs, npm globals, ~/.config,
# Claude Code auth, npm cache. Kept OUT of /srv on purpose — Filestash exposes
# /srv to the web and these dirs contain credentials.
# Override only if /var/lib is on a tiny partition.
# ----------------------------------------------------------------------------
LAB_STATE_DIR=/var/lib/mojalab/lab

# ----------------------------------------------------------------------------
# Email used for Let's Encrypt registration. Expiry warnings land here.
# Use a real mailbox you actually read.
# ----------------------------------------------------------------------------
ACME_EMAIL=admin@example.com

# ----------------------------------------------------------------------------
# Telegram bot — for Watchtower daily digest notifications.
# 1. Talk to @BotFather on Telegram, create a new bot, get the token.
# 2. Send any message to your new bot.
# 3. Get your chat ID from: https://api.telegram.org/bot<TOKEN>/getUpdates
# ----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
TELEGRAM_CHAT_ID=000000000

# Proactive alert thresholds (set any to 0 to disable that watcher).
# ALERT_DISK_PCT  : warn when any filesystem reaches this %% full
# ALERT_MEM_PCT   : warn when RAM usage exceeds this %%
# ALERT_LOAD      : warn when 1-min load avg >= this integer (0 = off)
# HEARTBEAT_HOURS : send "all good" summary every N hours (0 = no heartbeat)
# ALERT_SSH       : 1 = alert on every successful SSH login (needs /var/log mount)
# ALERT_AUTHELIA  : 1 = alert on every Authelia 1FA/2FA login (via dockerproxy)
# ALERT_COOLDOWN  : seconds between repeats of the same alert
ALERT_DISK_PCT=85
ALERT_MEM_PCT=90
ALERT_LOAD=0
HEARTBEAT_HOURS=3
ALERT_SSH=1
ALERT_AUTHELIA=1
ALERT_COOLDOWN=3600

# ----------------------------------------------------------------------------
# SMTP — used by Authelia to deliver TOTP enrollment OTPs, password reset
# emails, etc. Without SMTP, Authelia writes notifications to a file inside
# the container (notification.txt) and you'll have to read codes from there.
#
# Defaults below target Resend (https://resend.com): create an API key, verify
# a sending domain, then drop the API key in SMTP_PASSWORD.
#
# Leave SMTP_HOST empty to disable SMTP and use the filesystem notifier.
# ----------------------------------------------------------------------------
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USERNAME=resend
SMTP_PASSWORD=re_xxxxxxxxxxxxxxxxxxxxxxxx
SMTP_SENDER=Authelia <noreply@lab.example.com>
